# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bosker

# ============================================
# API Configuration
# ============================================
# Local development (update to your backend URL)
NEXT_PUBLIC_BFF_URL=http://localhost:3001/graphql

# Production example:
# NEXT_PUBLIC_BFF_URL=https://api.bosker.app/graphql

# Vercel production example:
# NEXT_PUBLIC_BFF_URL=https://api.bosker.vercel.app/graphql

# API timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=10000

# ============================================
# Analytics (Optional)
# ============================================
# Google Analytics ID
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# ============================================
# Feature Flags
# ============================================
# Enable/disable chat functionality
NEXT_PUBLIC_ENABLE_CHAT=false

# Enable/disable ratings and reviews
NEXT_PUBLIC_ENABLE_RATINGS=true

# Enable/disable bookmarks/favorites
NEXT_PUBLIC_ENABLE_BOOKMARKS=true

# ============================================
# Environment Setup Instructions
# ============================================
# 1. Copy this file to .env.local
#    cp .env.example .env.local
#
# 2. Update values for your environment:
#    - Development: Use localhost URLs
#    - Staging: Use staging API endpoint
#    - Production: Use production API endpoint
#
# 3. Never commit .env.local to git
#    (already in .gitignore)
#
# 4. For Vercel deployment:
#    - Add these variables in Vercel dashboard
#    - Use production URLs
#    - Keep GA_ID blank if not using analytics
